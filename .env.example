cat > .env.example << 'EOF'
# PostgreSQL
POSTGRES_USER=nexusflow
POSTGRES_PASSWORD=
POSTGRES_DB=nexusflow_db
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# Redis
REDIS_URL=redis://localhost:6379

# FastAPI
API_HOST=0.0.0.0
API_PORT=8000
DEBUG=true

# JWT
JWT_SECRET=
JWT_EXPIRE_MINUTES=60

# Azure OpenAI
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_ENDPOINT=

# OpenAI (dev)
OPENAI_API_KEY=

# Azure Notification Hubs
AZURE_NOTIFICATION_HUB_CONNECTION_STRING=
AZURE_NOTIFICATION_HUB_NAME=nexusflow-hub

# Firebase
FIREBASE_PROJECT_ID=
FIREBASE_SENDER_ID=

# Expo
EXPO_TOKEN=

# Azure (deploy)
AZURE_CLIENT_ID=
AZURE_CLIENT_SECRET=
AZURE_TENANT_ID=
AZURE_SUBSCRIPTION_ID=
EOF